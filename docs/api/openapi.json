{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
          "App"
        ]
      }
    },
    "/api/v1/products/{id}/card": {
      "get": {
        "operationId": "ProductsController_getProductCard",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product card returned successfully."
          },
          "404": {
            "description": "Product was not found."
          }
        },
        "summary": "Get a product card with top offers and summary stats",
        "tags": [
          "products"
        ]
      }
    },
    "/api/v1/products/{id}/offers": {
      "get": {
        "operationId": "ProductsController_getProductOffers",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "inStock",
            "required": false,
            "in": "query",
            "description": "When true, return only in-stock offers",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sort",
            "required": false,
            "in": "query",
            "description": "Sort field for offers",
            "schema": {
              "enum": [
                "price",
                "discount",
                "updated"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product offers returned successfully."
          },
          "400": {
            "description": "Invalid query parameters."
          },
          "404": {
            "description": "Product was not found."
          }
        },
        "summary": "Get product offers with sorting and stock filtering",
        "tags": [
          "products"
        ]
      }
    },
    "/api/v1/products/{id}/price-history": {
      "get": {
        "operationId": "ProductsController_getProductPriceHistory",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "period",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "pattern": "^(\\d+)(d|w|m)$",
              "default": "30d"
            },
            "description": "Time period, e.g. 30d, 2w, 3m"
          }
        ],
        "responses": {
          "200": {
            "description": "Product price history returned successfully."
          },
          "400": {
            "description": "Invalid period format."
          },
          "404": {
            "description": "Product was not found."
          }
        },
        "summary": "Get product price history for a given period",
        "tags": [
          "products"
        ]
      }
    },
    "/api/v1/products/{id}/related": {
      "get": {
        "operationId": "ProductsController_getRelatedProducts",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Maximum related products count",
            "schema": {
              "minimum": 1,
              "maximum": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Related products returned successfully."
          },
          "400": {
            "description": "Invalid limit value."
          },
          "404": {
            "description": "Product was not found."
          }
        },
        "summary": "Get related products",
        "tags": [
          "products"
        ]
      }
    }
  },
  "info": {
    "title": "Shop Comparison Platform API",
    "description": "Backend API for product cards, offers, price history, and related products.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "products",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "schemas": {}
  }
}