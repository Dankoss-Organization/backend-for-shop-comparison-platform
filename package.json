{
  "name": "shop-comparison-platform",
  "version": "1.0.0",
  "description": "This repository contains the server-side logic, database management, and business orchestration layer for the Shop Comparison Platform. It serves as the central hub that processes data from various scrapers, manages the product catalog, and provides a high-performance API for the frontend.",
  "main": "index.js",
  "scripts": {
    "start": "nest start backend",
    "start:dev": "nest start backend --watch",
    "start:worker": "ts-node -P apps/backend/tsconfig.app.json apps/backend/src/worker.ts",
    "start:worker:dev": "ts-node-dev --project apps/backend/tsconfig.app.json --respawn --transpile-only apps/backend/src/worker.ts",
    "start:debug": "nest start backend --debug --watch",
    "build": "nest build backend",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:db": "jest --config ./src/db-tests/jest.db.config.js",
    "test:db:watch": "jest --config ./src/db-tests/jest.db.config.js --watch",
    "test:e2e": "jest --config ./apps/backend/test/jest-e2e.json",
    "docs:api": "ts-node apps/backend/src/scripts/generate-api-docs.ts",
    "docs:db": "prisma generate && ts-node apps/backend/src/scripts/generate-db-docs-index.ts",
    "docs:build": "npm run docs:api && npm run docs:db",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "^7.6.0",
    "prisma-docs-generator": "^0.8.0",
    "prisma-erd-generator": "^2.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bullmq": "^5.76.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
