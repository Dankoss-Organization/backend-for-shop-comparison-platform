generator client {
  provider = "prisma-client-js"
}

generator docs {
  provider = "node node_modules/prisma-docs-generator"
  output   = "../docs/db/reference"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "../docs/db/erd.svg"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String          @id @default(uuid())
  name        String
  phoneNumber String?
  email       String          @unique
  password    String
  createdAt   DateTime        @default(now())
  photo       String?
  allergens   Allergen[]
  carts       Cart[]          @relation("UserToCart")
  diets       Diet[]
  favourites  UserFavourite[]

  @@map("users")
}

model UserFavourite {
  id                 String            @id @default(uuid())
  userId             String
  storeId            String?
  favouriteProductId String?           @map("prId")
  favouriteRecipeId  String?           @map("repId")
  recipeId           String?           @map("recipe_id")
  favouriteProduct   FavouriteProduct? @relation("PrFavourites", fields: [favouriteProductId], references: [id])
  recipe             Recipe?           @relation("RecipeFavourites", fields: [recipeId], references: [id])
  favouriteRecipe    FavouriteRecipe?  @relation("RepFavourites", fields: [favouriteRecipeId], references: [id])
  store              FavouriteStore?   @relation("StoreFavourites", fields: [storeId], references: [id])
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([storeId])
  @@index([favouriteProductId])
  @@index([favouriteRecipeId])
  @@index([recipeId])
  @@map("user_favourites")
}

model FavouriteStore {
  id           String          @id @default(uuid())
  localStoreId String          @unique
  localStore   LocalStore      @relation(fields: [localStoreId], references: [id], onDelete: Cascade)
  favourites   UserFavourite[] @relation("StoreFavourites")

  @@map("favourite_stores")
}

model FavouriteProduct {
  id         String          @id @default(uuid())
  productId  String          @unique @map("product_id")
  product    Product         @relation("ProductToFavourite", fields: [productId], references: [id], onDelete: Cascade)
  favourites UserFavourite[] @relation("PrFavourites")

  @@map("favourite_products")
}

model FavouriteRecipe {
  id         String          @id @default(uuid())
  recipeId   String          @unique @map("recipe_id")
  recipe     Recipe          @relation("RecipeToFavourite", fields: [recipeId], references: [id], onDelete: Cascade)
  favourites UserFavourite[] @relation("RepFavourites")

  @@map("favourite_recipes")
}

model Cart {
  id          String     @id @default(uuid())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isFinished  Boolean    @default(false)
  sum         Decimal    @default(0) @db.Decimal(12, 2)
  discountSum Decimal    @default(0) @db.Decimal(12, 2)
  paidTime    DateTime?
  isActive    Boolean    @default(true)
  userId      String     @map("user_id")
  items       CartItem[] @relation("CartItems")
  user        User       @relation("UserToCart", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id       String  @id @default(uuid())
  quantity Int     @default(1)
  price    Decimal @db.Decimal(12, 2)
  cartId   String
  offerId  String
  cart     Cart    @relation("CartItems", fields: [cartId], references: [id], onDelete: Cascade)
  offer    Offer   @relation("OfferToCartItem", fields: [offerId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([offerId])
  @@map("cart_items")
}

model Product {
  id                         String            @id @default(uuid())
  productId                  String            @unique
  canonicalName              String            @map("canonical_name")
  brand                      String?
  country                    String?
  media                      String
  measurements               Json
  pricingLogic               Json              @map("pricing_logic")
  description                String?
  calories                   String?
  proteins                   Float?            @map("proteins_g")
  fats                       Float?            @map("fats_g")
  carbohydrates              Float?            @map("carbohydrates_g")
  alcoholPercentage          Float?            @map("alcohol_percentage")
  isTobacco                  Boolean           @default(false) @map("is_tobacco")
  is18Plus                   Boolean           @default(false) @map("is_18_plus")
  isNationalCashbackEligible Boolean           @default(false) @map("is_national_cashback_eligible")
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  categoryId                 String?           @map("category_id")
  favouriteDetails           FavouriteProduct? @relation("ProductToFavourite")
  offers                     Offer[]           @relation("ProductToOffer")
  category                   ProductCategory?  @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([brand])
  @@map("product")
}

model Offer {
  id            String         @id @default(uuid())
  storeId       String         @map("store_id")
  productId     String         @map("product_id")
  currentPrice  Decimal        @map("current_price") @db.Decimal(12, 2)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  discountPrice Decimal?       @map("discount_price") @db.Decimal(12, 2)
  storeSku      String?        @map("store_sku")
  cartItems     CartItem[]     @relation("OfferToCartItem")
  product       Product        @relation("ProductToOffer", fields: [productId], references: [id], onDelete: Cascade)
  store         LocalStore     @relation("StoreToOffer", fields: [storeId], references: [id], onDelete: Cascade)
  priceHistory  PriceHistory[] @relation("OfferToPriceHistory")

  @@unique([storeId, productId])
  @@map("offers")
}

model PriceHistory {
  id           String    @id @default(uuid())
  offerId      String    @map("offer_id")
  price        Decimal   @db.Decimal(12, 2)
  regularPrice Decimal   @map("regular_price") @db.Decimal(12, 2)
  endDate      DateTime? @map("end_date")
  startDate    DateTime  @default(now()) @map("start_date")
  offer        Offer     @relation("OfferToPriceHistory", fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@map("price_history")
}

model ProductCategory {
  id            String            @id @default(uuid())
  name          String
  parentId      String?           @map("parent_id")
  allergens     Allergen[]
  diets         Diet[]
  ingredients   Ingredient[]      @relation("CategoryToIngredients")
  parent        ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subcategories ProductCategory[] @relation("CategoryHierarchy")
  products      Product[]

  @@index([parentId])
  @@map("pr_categories")
}

model StoreBrand {
  id          String       @id @default(uuid())
  name        String
  website     String?
  logo        String?
  localStores LocalStore[]

  @@map("store_brand")
}

model LocalStore {
  id               String          @id @default(uuid())
  longitude        Float
  latitude         Float
  address          String
  openingHour      String          @map("opening_hour")
  closingHour      String          @map("closing_hour")
  city             String
  brandId          String          @map("brand_id")
  favouriteDetails FavouriteStore?
  brand            StoreBrand      @relation(fields: [brandId], references: [id])
  offers           Offer[]         @relation("StoreToOffer")

  @@map("local_store")
}

model Diet {
  id         String           @id @default(uuid())
  name       String
  userId     String           @map("user_id")
  categoryId String?          @map("category_id")
  category   ProductCategory? @relation(fields: [categoryId], references: [id])
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@index([categoryId])
  @@map("diets")
}

model Allergen {
  id         String           @id @default(uuid())
  name       String
  userId     String           @map("user_id")
  categoryId String?          @map("category_id")
  category   ProductCategory? @relation(fields: [categoryId], references: [id])
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@index([categoryId])
  @@map("allergens")
}

model Recipe {
  id           String             @id @default(uuid())
  name         String
  instructions String
  difficulty   String
  prepTime     Int
  servings     Int
  imageUrl     String?            @map("image_url")
  categoryId   String
  favouritedBy FavouriteRecipe?   @relation("RecipeToFavourite")
  equipment    RecipeEquipment[]
  ingredients  RecipeIngredient[]
  category     RecipeCategory     @relation(fields: [categoryId], references: [id])
  reviews      Review[]
  favourites   UserFavourite[]    @relation("RecipeFavourites")

  @@index([categoryId])
  @@map("recipes")
}

model RecipeCategory {
  id       String           @id @default(uuid())
  name     String
  parentId String?
  parent   RecipeCategory?  @relation("CategoryToSub", fields: [parentId], references: [id])
  children RecipeCategory[] @relation("CategoryToSub")
  recipes  Recipe[]

  @@index([parentId])
  @@map("rec_categories")
}

model Review {
  id        String   @id @default(uuid())
  rate      Int
  comment   String?
  createdAt DateTime @default(now())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@map("reviews")
}

model Ingredient {
  id         String             @id @default(uuid())
  name       String
  imageUrl   String?            @map("image_url")
  categoryId String             @map("category_id")
  category   ProductCategory    @relation("CategoryToIngredients", fields: [categoryId], references: [id], onDelete: Cascade)
  recipes    RecipeIngredient[]

  @@map("ingredients")
}

model RecipeIngredient {
  id           String     @id @default(uuid())
  quantity     Float
  unit         String
  recipeId     String
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([ingredientId])
  @@map("recipe_ingredients")
}

model Equipment {
  id       String            @id @default(uuid())
  name     String
  imageUrl String?           @map("image_url")
  recipes  RecipeEquipment[]

  @@map("equipment")
}

model RecipeEquipment {
  id          String    @id @default(uuid())
  quantity    Int       @default(1)
  recipeId    String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([equipmentId])
  @@map("recipe_equipment")
}
