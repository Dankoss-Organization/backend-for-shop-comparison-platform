generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  name        String
  phoneNumber String?
  email       String   @unique
  password    String
  createdAt   DateTime @default(now())
  photo       String?

  favourites UserFavourites[]
  diets     Diet[]
  allergens Allergen[]
}

model UserFavourites {
  id       String @id @default(uuid())

  userId   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  storeId String?
  store   FavouriteStore? @relation("StoreFavourites", fields: [storeId], references: [id])

  prId     String?
  pr        FavouritePr?    @relation("PrFavourites", fields: [prId], references: [id])

  repId    String?
  rep       FavouriteRep?   @relation("RepFavourites", fields: [repId], references: [id])

  @@index([userId])
  @@index([storeId])
  @@index([prId])
  @@index([repId])
}

model FavouriteStore {
  id           String @id @default(uuid())

  localStoreId String @unique
  localStore   LocalStore @relation(fields: [localStoreId], references: [id], onDelete: Cascade)

  favourites   UserFavourites[] @relation("StoreFavourites")
}

model FavouritePr {
  id String @id @default(uuid())

  favourites  UserFavourites[] @relation("PrFavourites")
}

model FavouriteRep {
  id String @id @default(uuid())

  favourites  UserFavourites[] @relation("RepFavourites")
}

model Cart {
  id           String     @id @default(uuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  isFinished   Boolean    @default(false)
  sum          Float      @default(0)
  discountSum  Float      @default(0)
  paidTime     DateTime?
  isActive     Boolean    @default(true)

  items        CartItem[] @relation("CartItems")
}

model CartItem {
  id        String   @id @default(uuid())
  quantity  Int      @default(1)
  price     Float

  cartId    String
  cart      Cart @relation("CartItems", fields: [cartId], references: [id], onDelete: Cascade)

  offerId   String
  offer     Offer    @relation("OfferToCartItem", fields: [offerId], references: [id])

  @@index([cartId])
  @@index([offerId])
}

// Product cluster

model Product {
  id               String   @id @default(uuid())
  productId        String   @unique
  canonicalName    String   @map("canonical_name")
  brand            String?
  country          String?

  media            Json     

  measurements     Json  

  pricingLogic     Json     @map("pricing_logic")
  
  description      String?  @db.Text
  calories         Float?
  proteins         Float?   @map("proteins_g")
  fats             Float?   @map("fats_g")
  carbohydrates    Float?   @map("carbohydrates_g")
  alcoholPercentage Float?  @map("alcohol_percentage")
  
  isTobacco        Boolean  @default(false) @map("is_tobacco")
  is18Plus         Boolean  @default(false) @map("is_18_plus")
  isNationalCashbackEligible Boolean @default(false) @map("is_national_cashback_eligible")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  categoryId String?     @map("category_id")
  category   PrCategory? @relation(fields: [categoryId], references: [id])

  offers     Offer[] @relation("ProductToOffer")

  @@map("product")

  @@index([categoryId])
  @@index([brand])
}

model Offer {
  id        String   @id @default(uuid())
  
  storeId   String   @map("store_id")
  store     LocalStore @relation("StoreToOffer", fields: [storeId], references: [id], onDelete: Cascade)

  productId String   @map("product_id")
  product   Product  @relation("ProductToOffer", fields: [productId], references: [id], onDelete: Cascade)

  currentPrice Float    @map("current_price")
  
  priceHistory PriceHistory[] @relation("OfferToPriceHistory")
  cartItems    CartItem[]     @relation("OfferToCartItem")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, productId])
  @@map("offers")
}

model PriceHistory {
  id           String   @id @default(uuid())
  offerId      String   @map("offer_id")
  offer        Offer    @relation("OfferToPriceHistory", fields: [offerId], references: [id], onDelete: Cascade)

  date         DateTime @default(now())
  price        Float
  regularPrice Float    @map("regular_price")

  @@index([offerId])
  @@map("price_history")
}

model PrCategory {
  id        String   @id @default(uuid())
  name      String

  parentId  String?  @map("parent_id")
  
  parent    PrCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  
  subcategories PrCategory[] @relation("CategoryHierarchy")

  products Product[]

  @@index([parentId])
  @@map("pr_categories")

  diets     Diet[]
  allergens Allergen[]
}

model StoreBrand {
  id        String   @id @default(uuid())
  name      String
  website   String?
  logo      String?

  localStores LocalStore[]

  @@map("store_brand")
}

model LocalStore {
  id           String   @id @default(uuid())
  longitude    Float
  latitude     Float
  address      String
  openingHour  String   @map("opening_hour")
  closingHour  String   @map("closing_hour")
  city         String

  brandId      String   @map("brand_id")
  brand        StoreBrand @relation(fields: [brandId], references: [id])

  offers           Offer[] @relation("StoreToOffer")
  favouriteDetails FavouriteStore?

  @@map("local_store")
}

// DIET & ALLERGEN CLUSTER
model Diet {
  id        String   @id @default(uuid())
  name      String   @unique

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Зв'язок з PrCategory (Дієта стосується категорій)
  categoryId String? @map("category_id")
  category   PrCategory? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@map("diets")
}

model Allergen {
  id        String   @id @default(uuid())
  name      String   @unique

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String? @map("category_id")
  category   PrCategory? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@map("allergens")
}

// Recipe cluster

model Recipe {
  id           String   @id @default(uuid())
  name         String
  instructions String   @db.Text
  difficulty   String
  prepTime     Int      // Time in minutes
  servings     Int
  imageUrl     String?  @map("image_url")

  // Зв'язки
  categoryId   String
  category     RecCategory @relation(fields: [categoryId], references: [id])
  
  reviews      Reviews[]
  ingredients  RecipeIngredients[]
  equipment    RecipeEquipment[]

  @@index([categoryId])
}

model RecCategory {
  id        String   @id @default(uuid())
  name      String

  parentId  String?
  parent    RecCategory?  @relation("CategoryToSub", fields: [parentId], references: [id])
  children  RecCategory[] @relation("CategoryToSub")

  recipes   Recipe[]

  @@index([parentId])
}

model Reviews {
  id        String   @id @default(uuid())
  rate      Int      // From 1 to 5
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model Ingredients {
  id       String   @id @default(uuid())
  name     String
  imageUrl String?  @map("image_url")

  recipes  RecipeIngredients[]
}

model RecipeIngredients {
  id           String      @id @default(uuid())
  quantity     Float
  unit         String   

  recipeId     String
  recipe       Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  
  ingredientId String
  ingredient   Ingredients @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([ingredientId])
}

model Equipment {
  id       String   @id @default(uuid())
  name     String
  imageUrl String?  @map("image_url")

  recipes  RecipeEquipment[]
}

model RecipeEquipment {
  id          String    @id @default(uuid())
  quantity    Int       @default(1)

  recipeId    String
  recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([equipmentId])
}

